# Copy this file to .env and fill in the values (never commit .env).
# Single root env file — loaded by Hardhat, TS client, and .NET client.
# Python benchmarks: export all vars before running —
#   bash/WSL:  set -a; source .env; set +a; python benchmarks/...
#   PowerShell: Get-Content .env | ForEach-Object { if ($_ -match '^([^#].+?)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }

# ── EVM ───────────────────────────────────────────────────────────────────────
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
# For localnet: use Hardhat default account #0 (0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80)
# For Sepolia: replace with your funded account private key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC — get one from Alchemy or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Shared payment token — one MockERC20 for all EVM variants (from deploy output)
PAYMENT_TOKEN_ADDRESS=

# Set VARIANT to the active contract — FACTORY_ADDRESS_{VARIANT} and
# CAMPAIGN_ADDRESS_{VARIANT} are selected automatically
VARIANT=V1

# V1 — ERC-20 receipt tokens (from deploy output)
FACTORY_ADDRESS_V1=
CAMPAIGN_ADDRESS_V1=

# V2 — ERC-4626 vault shares (from deploy output)
FACTORY_ADDRESS_V2=
CAMPAIGN_ADDRESS_V2=

# V3 — ERC-1155 tier tokens (from deploy output)
FACTORY_ADDRESS_V3=
CAMPAIGN_ADDRESS_V3=

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# SOLANA_PROGRAM_ID_{VARIANT} is selected automatically — check Anchor.toml [programs.localnet]
# V4 — SPL Token classic (crowdfunding program)
SOLANA_PROGRAM_ID_V4=

# V5 — Token-2022 extensions (crowdfunding_token2022 program)
SOLANA_PROGRAM_ID_V5=

# Shared across V4 and V5 (populate after spl-token create-token / sol:create-campaign):
SOLANA_PAYMENT_MINT=
SOLANA_CAMPAIGN_ADDRESS=
SOLANA_CAMPAIGN_ID=0
